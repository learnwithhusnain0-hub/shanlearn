rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is admin
    function isAdmin() {
      let adminEmails = get(/databases/$(database)/documents/settings/admin).data.emails;
      return request.auth != null && 
             request.auth.token.email in adminEmails;
    }
    
    // APKs collection - public read, admin write
    match /apks/{document} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Settings collection - admin emails
    match /settings/admin {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Default deny for other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
